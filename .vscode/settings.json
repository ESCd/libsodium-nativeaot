{
  "csharp.debug.symbolOptions.searchMicrosoftSymbolServer": true,
  "csharp.debug.symbolOptions.searchNuGetOrgSymbolServer": true,
  "csharp.debug.symbolOptions.moduleFilter.mode": "loadOnlyIncluded",
  "csharp.debug.symbolOptions.moduleFilter.includedModules": [
    "Microsoft.*.dll",
  ],
  "csharp.format.enable": true,
  "csharp.suppressBuildAssetsNotification": true,
  "csharp.suppressHiddenDiagnostics": false,
  "dotnet.backgroundAnalysis.analyzerDiagnosticsScope": "fullSolution",
  "dotnet.backgroundAnalysis.compilerDiagnosticsScope": "fullSolution",
  "dotnet.codeLens.enableReferencesCodeLens": false,
  "dotnet.codeLens.enableTestsCodeLens": false,
  "dotnet.defaultSolution": "libsodium.slnx",
  "dotnet.formatting.organizeImportsOnFormat": true,
  "dotnet.navigation.navigateToDecompiledSources": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.cs": "${capture}.*.cs",
    "*.csproj": "${capture}.csproj.user,${capture}.props,${capture}.targets,packages.lock.json",
    "*.json": "${capture}.*.json",
  },
  "files.associations": {
    "*.slnf": "json",
    "*.*proj": "xml",
    "*.props": "msbuild",
    "*.targets": "msbuild"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.vs": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules/": true,
    "**/bin/": true,
    "**/obj/": true,
  },
  "html.format.wrapAttributes": "auto",
  "html.format.wrapLineLength": 0,
  // "omnisharp.enableLspDriver": true,
  "omnisharp.enableEditorConfigSupport": true,
  "omnisharp.projectFilesExcludePattern": "**/node_modules/**,**/.git/**,**/bower_components/**,**/.vs/**,**/bin/**,**/obj/**",
  "omnisharp.sdkIncludePrereleases": false,
  "omnisharp.useEditorFormattingSettings": false,
  "omnisharp.useModernNet": true,
  "npm.packageManager": "npm",
  "razor.format.enable": true
}